# ===== AI 模型 Key（可选，推荐通过设置 UI 配置） =====
# 默认使用 MiMo，支持 mimo / deepseek / kimi / openai

# MiMo
MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro

# DeepSeek
DEEPSEEK_API_KEY=

# Kimi (月之暗面)
KIMI_API_KEY=

# OpenAI
OPENAI_API_KEY=

# ===== 搜索 Key（可选，也可通过设置 UI 配置） =====
# Tavily 免费 1000次/月：https://tavily.com
